---
layout: empty
---
[
  {% for post in site.posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "category" : "{{ post.categories | join: ', ' }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date | date: "%Y-%m-%d" }}",
      "search"   : true,
      "tag"      : true
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]

